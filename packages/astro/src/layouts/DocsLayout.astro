---
// Documentation page layout — content flows directly into the BaseLayout
// main slot. The route handler decides what gets rendered inside.
import BaseLayout from './BaseLayout.astro'

interface Props {
  title: string
  description?: string
  alert?: { message: string, type?: string, dismissible?: boolean } | false
}

const { title, description, alert } = Astro.props
---

<BaseLayout title={title} description={description} alert={alert}>
  <div class="usa-section">
    <slot />
  </div>
</BaseLayout>
