---
// BaseLayout — owns the page shell shared by every layout in the framework:
// html/head/body, USWDS chrome (banner, header, footer, identifier), the
// SEO tag block, custom head injection, the skipnav target, and the
// client init script. Child layouts (DocsLayout, SplashLayout) consume
// this via slot, supplying whatever goes inside <main id="main-content">.
// Self-host fonts via Fontsource. Each package's index.css declares the
// @font-face blocks and points at its own woff2 files; Vite handles the
// CSS import, processes the @font-face declarations, and bundles the
// font files through its asset pipeline. The family names declared by
// these packages must match the `display-name` values in the custom
// typeface tokens registered in styles/_uswds.scss so USWDS's compiled
// font-family references resolve to these faces.
import '@fontsource-variable/public-sans'
import '@fontsource-variable/merriweather'
import '@fontsource-variable/roboto-mono'
// Resolve the regular-weight latin woff2 for each variable font through
// Vite so the bundler emits a hashed asset URL we can preload. Without
// these <link rel="preload"> hints the browser only discovers the woff2
// files after parsing the bundled CSS, which guarantees a FOUT —
// preloading kicks the fetch off in parallel with the HTML parse so the
// webfont is usually ready before first paint.
import merriweatherWoff2 from '@fontsource-variable/merriweather/files/merriweather-latin-wght-normal.woff2?url'
import publicSansWoff2 from '@fontsource-variable/public-sans/files/public-sans-latin-wght-normal.woff2?url'
import robotoMonoWoff2 from '@fontsource-variable/roboto-mono/files/roboto-mono-latin-wght-normal.woff2?url'

import '../styles/styles.scss'
import { SEO } from 'astro-seo'
import config from 'virtual:red-glare/config'

import Footer from '../components/Footer.astro'
import GovBanner from '../components/GovBanner.astro'
import Header from '../components/Header.astro'
import Identifier from '../components/Identifier.astro'
import SiteAlert from '../components/SiteAlert.astro'

interface Props {
  title: string
  description?: string
  alert?: { message: string, type?: string, dismissible?: boolean } | false
}

const { title, description, alert } = Astro.props
const headTags = config.head ?? []
const pageTitle = `${title} | ${config.title}`
const canonicalUrl = new URL(
  Astro.url.pathname,
  Astro.site ?? 'http://localhost',
).href;
---

<html lang={config.defaultLocale ?? 'en'}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="preload" as="font" type="font/woff2" crossorigin href={publicSansWoff2} />
    <link rel="preload" as="font" type="font/woff2" crossorigin href={merriweatherWoff2} />
    <link rel="preload" as="font" type="font/woff2" crossorigin href={robotoMonoWoff2} />
    <SEO
      title={pageTitle}
      description={description}
      canonical={canonicalUrl}
      twitter={{
        card: 'summary',
        title: pageTitle,
        description,
      }}
    />
    {
      headTags.map(tag => (
        <Fragment
          set:html={`<${tag.tag} ${Object.entries(tag.attrs ?? {})
            .map(([k, v]) => (v === true ? k : `${k}="${v}"`))
            .join(' ')}>${tag.content ?? ''}</${tag.tag}>`}
        />
      ))
    }
  </head>
  <body>
    <a class="usa-skipnav" href="#main-content">Skip to main content</a>

    {config.governmentBanner && <GovBanner />}

    <SiteAlert alert={alert} />

    <Header currentPath={Astro.url.pathname} />

    <div class="usa-section">
      <main id="main-content">
        <slot />
      </main>
    </div>

    <Footer />
    <Identifier />

    <script src="../scripts/uswds-init.ts"></script>
  </body>
</html>
