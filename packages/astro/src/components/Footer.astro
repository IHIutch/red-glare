---
import type { SvgComponent } from 'astro/types'

import FacebookIcon from '@uswds/uswds/img/usa-icons/facebook.svg'
import GitHubIcon from '@uswds/uswds/img/usa-icons/github.svg'
import InstagramIcon from '@uswds/uswds/img/usa-icons/instagram.svg'
import LinkedInIcon from '@uswds/uswds/img/usa-icons/linkedin.svg'
import RssIcon from '@uswds/uswds/img/usa-icons/rss_feed.svg'
import TwitterIcon from '@uswds/uswds/img/usa-icons/x.svg'
import YouTubeIcon from '@uswds/uswds/img/usa-icons/youtube.svg'
// USWDS Footer component
// https://designsystem.digital.gov/components/footer/
import config from 'virtual:starsandstripes/config'

const footer = config.footer
const links = footer?.links ?? []
const contact = footer?.contact
const social = footer?.social ?? []

interface SocialPlatform {
  icon: SvgComponent
  label: string
}

const socialPlatforms: Record<string, SocialPlatform> = {
  facebook: { icon: FacebookIcon, label: 'Facebook' },
  x: { icon: TwitterIcon, label: 'X' },
  youtube: { icon: YouTubeIcon, label: 'YouTube' },
  instagram: { icon: InstagramIcon, label: 'Instagram' },
  linkedin: { icon: LinkedInIcon, label: 'LinkedIn' },
  github: { icon: GitHubIcon, label: 'GitHub' },
  rss: { icon: RssIcon, label: 'RSS feed' },
};
---

<footer class="usa-footer">
  <div class="grid-container usa-footer__return-to-top">
    <a href="#">Return to top</a>
  </div>

  {
    links.length > 0
? (
      <div class="usa-footer__primary-section">
        <nav class="usa-footer__nav" aria-label="Footer navigation">
          <ul class="grid-row grid-gap">
            {links.map(item => (
              <li class="mobile-lg:grid-col-4 desktop:grid-col-auto usa-footer__primary-content">
                <a class="usa-footer__primary-link" href={item.href}>
                  {item.label}
                </a>
              </li>
            ))}
          </ul>
        </nav>
      </div>
    )
: null
  }

  <div class="usa-footer__secondary-section">
    <div class="grid-container">
      <div class="grid-row grid-gap">
        <div
          class="usa-footer__logo grid-row mobile-lg:grid-col-6 mobile-lg:grid-gap-2"
        >
          {config.logo && (
            <div class="mobile-lg:grid-col-auto">
              <img
                class="usa-footer__logo-img"
                src={config.logo}
                alt=""
              />
            </div>
          )}
          <div class="mobile-lg:grid-col-auto">
            <p class="usa-footer__logo-heading">{config.title}</p>
          </div>
        </div>
        <div class="usa-footer__contact-links mobile-lg:grid-col-6">
          {
            social.length > 0
? (
              <div class="usa-footer__social-links grid-row grid-gap-1">
                {social.map((item) => {
                  const platform = socialPlatforms[item.platform]
                  const Icon = platform.icon
                  return (
                    <div class="grid-col-auto">
                      <a
                        class="usa-social-link"
                        href={item.href}
                        aria-label={platform.label}
                      >
                        <Icon
                          class="usa-social-link__icon"
                          aria-hidden="true"
                        />
                      </a>
                    </div>
                  )
                })}
              </div>
            )
: null
          }
          {
            contact
? (
              <>
                {contact.heading
? (
                  <p class="usa-footer__contact-heading">{contact.heading}</p>
                )
: null}
                <address class="usa-footer__address">
                  <div class="usa-footer__contact-info grid-row grid-gap">
                    {contact.phone
? (
                      <div class="grid-col-auto">
                        <div class="usa-footer__contact-info">
                          <a href={`tel:${contact.phone}`}>{contact.phone}</a>
                        </div>
                      </div>
                    )
: null}
                    {contact.email
? (
                      <div class="grid-col-auto">
                        <div class="usa-footer__contact-info">
                          <a href={`mailto:${contact.email}`}>
                            {contact.email}
                          </a>
                        </div>
                      </div>
                    )
: null}
                  </div>
                </address>
              </>
            )
: null
          }
        </div>
      </div>
    </div>
  </div>
</footer>
