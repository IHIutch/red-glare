<div class="usa-search usa-search--small" role="search" id="pagefind-search">
  <label class="usa-sr-only" for="search-field">Search</label>
  <input
    class="usa-input"
    id="search-field"
    type="search"
    name="search"
    placeholder="Search documentation..."
  />
</div>

<script>
  // Pagefind auto-initializes via astro-pagefind integration.
  // This script wires up the USWDS search input to Pagefind's UI.
  // PagefindUI's constructor mutates the target container to install
  // its own DOM — the returned instance isn't needed, but eslint
  // flags `new …()` as a side-effect, so we assign and ignore it.
  window.addEventListener('DOMContentLoaded', () => {
    const container = document.getElementById('pagefind-search')
    // @ts-expect-error: Property 'PagefindUI' does not exist on type 'Window & typeof globalThis'.
    if (container && window.PagefindUI) {
      container.innerHTML = ''

      // @ts-expect-error: Property 'PagefindUI' does not exist on type 'Window & typeof globalThis'.
      void new window.PagefindUI({ element: container, showSubResults: true })
    }
  })
</script>
