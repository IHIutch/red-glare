<div
  id="pagefind-search"
  class="pagefind-init"
  data-pagefind-ui
  data-bundle-path="/pagefind/"
>
  <label class="usa-sr-only" for="pagefind-search-input">Search documentation</label>
</div>

<script>
  // Pagefind ships a default UI that renders its own search input + results
  // dropdown. Its CSS lives alongside the JS, so both have to be pulled in
  // explicitly — `astro-pagefind` runs the indexer at build time, but it
  // doesn't register the runtime UI for us.
  import { PagefindUI } from '@pagefind/default-ui'
  import '@pagefind/default-ui/css/ui.css'

  function initPagefind() {
    const el = document.getElementById('pagefind-search')
    if (!el || !el.classList.contains('pagefind-init'))
      return
    const bundlePath = el.getAttribute('data-bundle-path') ?? '/pagefind/'
    // eslint-disable-next-line no-new
    new PagefindUI({
      element: '#pagefind-search',
      bundlePath,
      showSubResults: true,
    })
    el.classList.remove('pagefind-init')
  }

  if (document.readyState === 'loading')
    document.addEventListener('DOMContentLoaded', initPagefind)
  else
    initPagefind()
</script>
