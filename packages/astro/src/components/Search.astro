<div class="usa-search usa-search--small" role="search" id="pagefind-search">
  <label class="usa-sr-only" for="search-field">Search</label>
  <input
    class="usa-input"
    id="search-field"
    type="search"
    name="search"
    placeholder="Search documentation..."
  />
</div>

<script>
  // Pagefind auto-initializes via astro-pagefind integration
  // This script wires up the USWDS search input to Pagefind's UI
  window.addEventListener('DOMContentLoaded', () => {
    const container = document.getElementById('pagefind-search')
  if (container && window.PagefindUI) {
      container.innerHTML = ''
      new window.PagefindUI({ element: container, showSubResults: true })
  }
  })
</script>
