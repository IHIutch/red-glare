---
import { getCollection } from 'astro:content'
// USWDS Breadcrumb navigation
// https://designsystem.digital.gov/components/breadcrumb/
import config from 'virtual:red-glare/config'

interface Props {
  currentPath: string
  title: string
}

const { currentPath, title } = Astro.props

// The set of paths that actually have a page. Intermediate breadcrumb
// segments that don't match a real page render as plain text (no link),
// since clicking them would 404 — a common trap for folder-based docs
// where authors don't add an `index.md` per group.
const docs = await getCollection('docs')
const validPaths = new Set(
  docs.map(entry => `/${entry.id === 'index' ? '' : `${entry.id}/`}`),
)

// Build breadcrumb trail from URL path
const segments = currentPath.split('/').filter(Boolean)
const crumbs = [
  { label: config.title, href: '/', hasPage: true },
  ...segments.map((segment, i) => {
    const href = `/${segments.slice(0, i + 1).join('/')}/`
    return {
      label: segment.replace(/-/g, ' ').replace(/\b\w/g, c => c.toUpperCase()),
      href,
      hasPage: validPaths.has(href),
    }
  }),
]

// Replace last crumb label with actual page title
if (crumbs.length > 1) {
  crumbs[crumbs.length - 1].label = title
}
---

{crumbs.length > 1 && (
  <nav class="usa-breadcrumb" aria-label="Breadcrumbs">
    <ol class="usa-breadcrumb__list">
      {crumbs.map((crumb, i) => (
        <li
          class={`usa-breadcrumb__list-item ${i === crumbs.length - 1 ? 'usa-current' : ''}`}
          aria-current={i === crumbs.length - 1 ? 'page' : undefined}
        >
          {i === crumbs.length - 1 || !crumb.hasPage
? (
            <span>{crumb.label}</span>
          )
: (
            <a href={crumb.href} class="usa-breadcrumb__link">
              <span>{crumb.label}</span>
            </a>
          )}
        </li>
      ))}
    </ol>
  </nav>
)}
