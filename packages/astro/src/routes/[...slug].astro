---
import { getCollection } from 'astro:content'
import { ComarkRenderer } from '@comark/react'
import { parseContent } from '../comark'
import { extractHeadings } from '../utils/headings'
import DocsLayout from '../layouts/DocsLayout.astro'
import SplashLayout from '../layouts/SplashLayout.astro'
import Sidebar from '../components/Sidebar.astro'
import TableOfContents from '../components/TableOfContents.astro'
import Breadcrumbs from '../components/Breadcrumbs.astro'
import PrevNext from '../components/PrevNext.astro'
import EditLink from '../components/EditLink.astro'
import Alert from '../components/Alert'

export async function getStaticPaths() {
  const docs = await getCollection('docs')
  return docs.map((doc) => ({
    params: { slug: doc.id === 'index' ? undefined : doc.id },
    props: { doc },
  }))
}

const { doc } = Astro.props
const tree = await parseContent(doc.body!)
const headings = extractHeadings(tree)
const showToc = doc.data.toc !== false
const isSplash = doc.data.template === 'splash'
---

{isSplash ? (
  <SplashLayout title={doc.data.title} description={doc.data.description}>
    <article class="usa-prose">
      <ComarkRenderer tree={tree} components={{ Alert }} />
    </article>
  </SplashLayout>
) : (
  <DocsLayout title={doc.data.title} description={doc.data.description}>
    <div class="grid-container">
      <Breadcrumbs currentPath={Astro.url.pathname} title={doc.data.title} />
      <div class="grid-row grid-gap">
        <div class="tablet:grid-col-3">
          <Sidebar currentPath={Astro.url.pathname} />
        </div>
        <div class={showToc ? 'tablet:grid-col-6' : 'tablet:grid-col-9'}>
          <article class="usa-prose">
            <h1>{doc.data.title}</h1>
            <ComarkRenderer tree={tree} components={{ Alert }} />
          </article>
          <div class="margin-top-4">
            <EditLink filePath={doc.filePath} />
          </div>
          <PrevNext currentId={doc.id} />
        </div>
        {showToc && headings.length > 0 && (
          <div class="tablet:grid-col-3">
            <TableOfContents headings={headings} />
          </div>
        )}
      </div>
    </div>
  </DocsLayout>
)}
