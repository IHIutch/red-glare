---
import { getCollection } from 'astro:content'

import type { DocsEntry } from '../schema'

import { extractSummaryText, parseContent } from '../comark'
import Article from '../components/Article'
import EditLink from '../components/EditLink.astro'
import PrevNext from '../components/PrevNext.astro'
import Sidebar from '../components/Sidebar.astro'
import TableOfContents from '../components/TableOfContents.astro'
import DocsLayout from '../layouts/DocsLayout.astro'
import SplashLayout from '../layouts/SplashLayout.astro'
import { getBuildConfig } from '../utils/build-config'
import { extractHeadings } from '../utils/headings'
import { validateLinks } from '../utils/link-validator'
import { getCachedTree, setCachedTree } from '../utils/tree-cache'

export async function getStaticPaths() {
  // getCollection returns `any` inside integration packages — Astro's
  // collection types are codegen'd in the user project, not the library.
  // We need "unknown" since docs is inferred as "any" first.
  const docs = (await getCollection('docs')) as unknown as DocsEntry[]

  // Parse every doc once and cache the tree (in a shared module so
  // Astro's hoisted `getStaticPaths` scope and the page render scope
  // see the same Map). Run the link validator against the parsed set
  // before returning paths so broken internal links fail the build
  // up front, not halfway through rendering.
  const parsed = await Promise.all(
    docs.map(async (doc) => {
      const tree = await parseContent(doc.body!)
      setCachedTree(doc.id, tree)
      return { slug: doc.id, tree }
    }),
  )

  const { site, base } = getBuildConfig()
  const report = validateLinks(parsed, { site, base })
  if (report.broken.length > 0) {
    const formatted = report.broken
      .map(b => `  - [${b.sourceSlug}] ${b.href} — ${b.reason}`)
      .join('\n')
    throw new Error(
      `Link validator found ${report.broken.length} broken `
      + `internal link${report.broken.length === 1 ? '' : 's'} `
      + `across ${report.checked} check${report.checked === 1 ? '' : 's'}:\n${formatted}`,
    )
  }

  return docs.map(doc => ({
    params: { slug: doc.id === 'index' ? undefined : doc.id },
    props: { doc },
  }))
}

const { doc } = Astro.props
const tree = getCachedTree(doc.id) ?? await parseContent(doc.body!)
const headings = extractHeadings(tree)
// Frontmatter description wins; otherwise fall back to the <!-- more --> summary
const description = doc.data.description ?? extractSummaryText(tree) ?? undefined
// API reference pages auto-hide the right-hand TOC column so wide
// parameter tables and code samples get the full grid width. Authors
// can still deep-link into each endpoint's h2 (slugs are backfilled
// by `attachTocHeadings`) — they just don't get the navigation strip.
const isApi = doc.data.template === 'api'
const showToc = doc.data.toc !== false
const isSplash = doc.data.template === 'splash';
---

{
  isSplash
  ? (
    <SplashLayout title={doc.data.title} description={description}>
      <article>
        <Article
          tree={tree}
          className="usa-prose"
          client:visible
        />
      </article>
    </SplashLayout>
  )
: (
    <DocsLayout title={doc.data.title} description={description}>
      <div class="grid-container">
        <div class="grid-row grid-gap">
          <div class="tablet:grid-col-auto width-card-lg">
            <Sidebar currentPath={Astro.url.pathname} />
          </div>
          <div class="tablet:grid-col">
            <div class="grid-row grid-gap">
              {!isApi && (
                <div class="display-none tablet:display-block grid-col-auto width-card-lg order-last">
                  {showToc && headings.length > 0 && (
                    <TableOfContents headings={headings} />
                  )}
                </div>
              )}
              <div class="grid-col">
                <article>
                  <h1 class="margin-top-0">
                    {doc.data.title}
                    {isApi && doc.data.apiVersion && (
                      <span class="usa-tag margin-left-1 font-sans-2xs bg-base-lighter text-base-darker">
                        v{doc.data.apiVersion}
                      </span>
                    )}
                  </h1>
                  <Article
                    tree={tree}
                    className="usa-prose"
                    client:visible
                  />
                </article>
                <div class="margin-top-4">
                  <EditLink filePath={doc.filePath} />
                </div>
                <PrevNext currentId={doc.id} />
              </div>
            </div>
          </div>
        </div>
      </div>
    </DocsLayout>
  )
}
