---
// 404 page — USWDS-styled not found page with full site chrome
import DocsLayout from '../layouts/DocsLayout.astro'
---

<DocsLayout title="Page Not Found">
  <section class="usa-section">
    <div class="grid-container">
      <div class="grid-row grid-gap">
        <div class="tablet:grid-col-8 tablet:grid-offset-2 text-center">
          <h1 class="font-heading-3xl margin-bottom-2">404</h1>
          <p class="usa-intro">
            The page you're looking for might have been moved or no longer exists.
          </p>
          <a href="/" class="usa-button margin-top-4">Return to homepage</a>
        </div>
      </div>
    </div>
  </section>
</DocsLayout>
